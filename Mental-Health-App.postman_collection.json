        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "",
                  "const token = json.token || json.accessToken || json.jwt || json.data?.token;",
                  "if (token) pm.collectionVariables.set('token', token);",
                  "",
                  "const userId = json.user?.id || json.usuario?.id || json.data?.user?.id;",
                  "if (userId) pm.collectionVariables.set('userId', String(userId));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
