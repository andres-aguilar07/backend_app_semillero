        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "",
                  "const token = json.token || json.accessToken || json.jwt || json.data?.token;",
                  "if (token) pm.collectionVariables.set('token', token);",
                  "",
                  "pm.test('Token presente', function () {",
                  "  pm.expect(token).to.be.ok;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@test.com\",\n  \"contrasena\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
